# --------------------------------------------------------------------------
# SECURE ENVIRONMENT VARIABLES & SENSITIVE DATA
# --------------------------------------------------------------------------

# Ignore all environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Ignore secret keys and certificates
*.key
*.cert
*.cert.pem
*.key.pem
*.p12
*.pfx

# Ignore credentials and config files containing secrets
secret.json
secrets.json
credentials.json
aws-credentials.json
.aws/
.gcp/
.azure/

# Ignore local databases that might contain sensitive data
*.sqlite
*.sqlite3
*.db

# --------------------------------------------------------------------------
